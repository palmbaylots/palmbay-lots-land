      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst files = (data && data.files) || [];\nconst target = $('Validate slug').first().json.filename;\nconst match = files.find(f => f.name === target);\nif (!match) {\n  throw new Error('File \"' + target + '\" not found in Drive folder 13CFbBbe4SesEhAXF7xCSy1wq6VMRB0Y9. Drive returned ' + files.length + ' file(s) in this folder: [' + files.map(f => f.name).join(', ') + ']. Check filename spelling, case, .json extension, and that the file is in this exact folder.');\n}\nreturn [{ json: { fileId: match.id, name: match.name } }];"
