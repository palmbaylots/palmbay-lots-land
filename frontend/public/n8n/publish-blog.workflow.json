      "position": [680, 320]
    },
    {
      "parameters": {
        "jsCode": "// Pick the exact matching file by name.\nconst data = $input.first().json;\nconst files = (data && data.files) || [];\nconst target = $('Validate slug').first().json.filename;\nconst match = files.find(f => f.name === target);\nif (!match) {\n  const found = files.map(f => f.name).join(', ') || '(none)';\n  throw new Error('File \"' + target + '\" not found in Drive folder. Files matched: ' + found);\n}\nreturn [{ json: { fileId: match.id, name: match.name } }];"
      },
      "id": "f1a0b001-aa01-4001-aaaa-000000000004",
      "name": "Pick file",
      "type": "n8n-nodes-base.code",
