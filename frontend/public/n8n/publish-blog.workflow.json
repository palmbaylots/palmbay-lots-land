      "typeVersion": 4.2,
      "position": [1120, 320]
    },
    {
      "parameters": {
        "jsCode": "// Build the API payload. Drive returned the parsed JSON in $json directly.\nconst payload = $input.first().json;\nconst slug = $('Validate slug').first().json.slug;\nif (!payload || typeof payload !== 'object') {\n  throw new Error('Drive file did not return a JSON object');\n}\nconst body = {\n  slug,\n  title: payload.title || '',\n  metaTitle: payload.metaTitle || payload.title || '',\n  metaDescription: payload.metaDescription || payload.subtitle || '',\n  subtitle: payload.subtitle || '',\n  category: payload.category || 'General',\n  date: payload.date || new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' }),\n  readTime: payload.readTime || '5 min read',\n  image: payload.image || '',\n  content: payload.content || '',\n  faqs: Array.isArray(payload.faqs) ? payload.faqs : []\n};\nif (!body.title || !body.content) {\n  throw new Error('Drive JSON must include title and content');\n}\nreturn [{ json: body }];"
      },
