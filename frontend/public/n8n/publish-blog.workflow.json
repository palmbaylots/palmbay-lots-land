        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst slug = (body.slug || '').trim();\nif (!slug) throw new Error('Missing required field: slug');\nif (!/^[a-z0-9-]+$/.test(slug)) {\n  throw new Error('Invalid slug \"' + slug + '\" — lowercase letters, numbers, and hyphens only');\n}\nreturn [{ json: { slug, filename: slug + '.json' } }];"
