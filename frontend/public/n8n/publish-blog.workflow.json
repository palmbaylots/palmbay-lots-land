      "parameters": {
        "jsCode": "// Collect the upstream error and emit a structured payload for the error responder.\nconst item = $input.first();\nconst json = item.json || {};\nconst errObj = item.error || {};\n// n8n routes errors with various shapes — extract message from any of them.\nconst msg = errObj.message\n  || (errObj.cause && errObj.cause.message)\n  || json.message\n  || (typeof json.error === 'string' ? json.error : (json.error && json.error.message))\n  || JSON.stringify(json).slice(0, 1000);\nconst sourceNode = errObj.node?.name\n  || (item.error && item.error.context && item.error.context.nodeName)\n  || 'unknown';\nreturn [{\n  json: {\n    ok: false,\n    failedNode: sourceNode,\n    error: msg,\n    receivedSlug: ($('Validate slug').first()?.json || {}).slug || null,\n    debug: {\n      jsonKeys: Object.keys(json),\n      errorKeys: Object.keys(errObj),\n      hasMessage: !!errObj.message\n    }\n  }\n}];"
